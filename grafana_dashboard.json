{
  "title": "Tee Time Finder",
  "uid": "teetime-finder",
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scraper Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "teetime_run_success",
        "legendFormat": ""
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Last Run",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "time() - teetime_last_run_timestamp_seconds",
        "legendFormat": ""
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 600 },
              { "color": "red", "value": 1200 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "On Tee Sheet",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "teetime_player_found",
        "legendFormat": ""
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NOT ENTERED", "color": "yellow" }, "1": { "text": "ENTERED", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Your Tee Time",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "teetime_player_time_minutes",
        "legendFormat": ""
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "-1": { "text": "—", "color": "grey" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 600 }
            ]
          },
          "displayName": "mins past midnight"
        }
      }
    },
    {
      "id": 5,
      "title": "Early Slots Available",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "teetime_early_slots_available",
        "legendFormat": ""
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "grey", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Alert Sent",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "teetime_alert_sent",
        "legendFormat": ""
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "—", "color": "grey" }, "1": { "text": "SENT", "color": "blue" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "grey", "value": 0 }, { "color": "blue", "value": 1 }] }
        }
      }
    },
    {
      "id": 7,
      "title": "Early Slots Available (24h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "teetime_early_slots_available",
        "legendFormat": "Early slots"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "grey", "value": 0 }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 8,
      "title": "Your Tee Time (24h)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "teetime_player_time_minutes",
        "legendFormat": "Tee time (mins)"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2 },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 600 }]
          },
          "color": { "mode": "thresholds" }
        }
      }
    }
  ],
  "schemaVersion": 38
}
